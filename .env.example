# PostgreSQL connection string from Neon
DATABASE_URL=

# Random secret used to sign Payload auth tokens (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=

# Resend API key for transactional email
RESEND_API_KEY=

# From address for outgoing emails (must be a verified domain in Resend)
RESEND_FROM_EMAIL=

# Public URL of the deployed app (no trailing slash, e.g. https://southeastsocial.com)
NEXT_PUBLIC_SERVER_URL=

# Vercel Blob read/write token
BLOB_READ_WRITE_TOKEN=

# Secret bearer token for the /api/send-digest cron endpoint
DIGEST_SECRET=
